# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Stellar Network ──────────────────────────────────────────────────────────
# Options: testnet | mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ─── Stellar Wallets Kit ──────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WALLET_APP_NAME=StellarAid
NEXT_PUBLIC_WALLET_APP_DESCRIPTION=Blockchain-based crowdfunding on Stellar
NEXT_PUBLIC_WALLET_APP_URL=https://stellaraid.app
NEXT_PUBLIC_WALLET_APP_ICON=https://stellaraid.app/icon.png

# ─── Auth (server-only) ───────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
AUTH_SECRET=change-me-to-a-random-32-char-string

# ─── Database (server-only) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/stellaraid

# ─── OAuth (server-only) ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stellar Admin (server-only — never expose to client) ─────────────────────
STELLAR_ADMIN_SECRET_KEY=
